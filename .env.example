# ============================================================
# Claude Setup - Variables de entorno (NUNCA commitear .env)
# Copia este archivo a .env y completa los valores reales
# ============================================================

# --- n8n MCP ---
N8N_BASE_URL=https://tu-instancia.app.n8n.cloud
N8N_API_KEY=tu_api_key_aqui

# --- docx-drive MCP ---
# Usa las rutas donde guardes tus credenciales de Google Drive para el server gdrive.
GDRIVE_CREDENTIALS_PATH=C:\Users\TU_USUARIO\.codex\mcp\docx_drive\.gdrive-server-credentials.json
GDRIVE_OAUTH_PATH=C:\Users\TU_USUARIO\.codex\mcp\docx_drive\gcp-oauth.keys.json

# --- Google OAuth (google-docs-mcp) ---
# El token se guarda automaticamente en:
# Windows: %USERPROFILE%\.config\google-docs-mcp\token.json
# Ver mcps/google-docs-mcp/LOCAL_SETUP.md para el flow completo

# --- Canva / Miro (OAuth via browser) ---
# No requieren variables de entorno.
# Se autentican la primera vez que usas una tool en Claude Code.
