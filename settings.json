{
  "permissions": {
    "allow": [
      "*"
    ],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": []
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File \"SETUP_DIR\\scripts\\context-monitor.ps1\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "co-researcher@co-researcher-marketplace": true,
    "claude-router@0xrdan-plugins": true
  },
  "extraKnownMarketplaces": {
    "co-researcher-marketplace": {
      "source": {
        "source": "github",
        "repo": "poemswe/co-researcher"
      }
    },
    "0xrdan-plugins": {
      "source": {
        "source": "github",
        "repo": "0xrdan/claude-plugins"
      }
    }
  },
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true,
  "voiceEnabled": true,
  "mcpServers": {
    "word-document-server": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "SETUP_DIR\\mcps\\word-document\\word_mcp_server.py"
      ],
      "env": {
        "GOOGLE_MCP_PROFILE": "GOOGLE_MCP_PROFILE_PLACEHOLDER"
      }
    },
    "google-workspace": {
      "type": "stdio",
      "command": "node",
      "args": [
        "SETUP_DIR\\mcps\\google-workspace-mcp\\dist\\index.js"
      ],
      "env": {}
    },
    "docx-editor-local": {
      "type": "stdio",
      "command": "node",
      "args": [
        "SETUP_DIR\\mcps\\docx-editor-local\\server.js"
      ],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "env": {}
    },
    "docx-drive": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-gdrive"
      ],
      "env": {
        "GDRIVE_CREDENTIALS_PATH": "DOCX_DRIVE_CREDENTIALS_PATH_PLACEHOLDER",
        "GDRIVE_OAUTH_PATH": "DOCX_DRIVE_OAUTH_PATH_PLACEHOLDER"
      }
    },
    "canva": {
      "type": "http",
      "url": "https://mcp.canva.com/mcp"
    },
    "miro": {
      "type": "http",
      "url": "https://mcp.miro.com/"
    },
    "n8n": {
      "type": "stdio",
      "command": "C:\\Users\\USUARIO\\claude-setup\\mcps\\n8n-wrapper.cmd",
      "args": [],
      "env": {}
    },
    "excel": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@negokaz/excel-mcp-server"
      ],
      "env": {}
    },
    "notion-easy": {
      "type": "stdio",
      "command": "easy-notion-mcp",
      "args": [],
      "env": {
        "NOTION_TOKEN": "NOTION_TOKEN_PLACEHOLDER"
      }
    }
  }
}
